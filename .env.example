# Hexa Octarina Conquer — Tehkné Solutions
PORT=8080
NODE_ENV=production

# Room state: postgres | sqlite | files | memory
# Use postgres for more than one server instance.
HEXA_STORE=postgres
HEXA_DB_PATH=/data/hexa-octarina.sqlite
HEXA_DATA_DIR=/data/rooms
HEXA_ROOM_PG_POOL_SIZE=10

# Accounts and global progression: postgres | sqlite | memory
HEXA_IDENTITY_STORE=postgres
HEXA_IDENTITY_DB_PATH=/data/hexa-identity.sqlite
HEXA_PG_POOL_SIZE=10

# Matchmaking, seasons, recovery and telemetry: postgres | memory
HEXA_COMPETITION_STORE=postgres
HEXA_COMPETITION_PG_POOL_SIZE=8

# Required by every PostgreSQL-backed service.
DATABASE_URL=postgresql://hexa:change-me@postgres:5432/hexa_octarina

# Recovery codes are returned by the protocol only outside production.
# Enable solely in controlled QA environments.
HEXA_RECOVERY_EXPOSE_CODE=false

# Public client endpoint example
HEXA_PUBLIC_WS_URL=wss://game.example.com/ws
