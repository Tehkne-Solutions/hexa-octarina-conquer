# Hexa Octarina Conquer — Tehkné Solutions
PORT=8080
NODE_ENV=production

# Room state: postgres | sqlite | files | memory
# Use postgres for more than one server instance.
HEXA_STORE=postgres
HEXA_DB_PATH=/data/hexa-octarina.sqlite
HEXA_DATA_DIR=/data/rooms
HEXA_ROOM_PG_POOL_SIZE=10

# Accounts and global progression: postgres | sqlite | memory
HEXA_IDENTITY_STORE=postgres
HEXA_IDENTITY_DB_PATH=/data/hexa-identity.sqlite
HEXA_PG_POOL_SIZE=10

# Matchmaking, seasons, recovery challenges and telemetry: postgres | memory
HEXA_COMPETITION_STORE=postgres
HEXA_COMPETITION_PG_POOL_SIZE=8

# Inter-replica events, presence and competitive governance.
HEXA_CLUSTER_BUS=postgres
HEXA_CLUSTER_PG_POOL_SIZE=4
HEXA_PRESENCE_STORE=postgres
HEXA_PRESENCE_PG_POOL_SIZE=4
HEXA_PRESENCE_TTL_MS=45000
HEXA_GOVERNANCE_STORE=postgres
HEXA_GOVERNANCE_PG_POOL_SIZE=4

# Required by every PostgreSQL-backed service.
DATABASE_URL=postgresql://hexa:change-me@postgres:5432/hexa_octarina

# Administrative HTTP endpoints under /admin/*.
HEXA_ADMIN_TOKEN=replace-with-a-long-random-secret

# Recovery delivery: webhook | console | none
# Production should use webhook or another future external provider.
HEXA_RECOVERY_PROVIDER=webhook
HEXA_RECOVERY_WEBHOOK_URL=https://automation.example.com/hexa/recovery
HEXA_RECOVERY_WEBHOOK_SECRET=replace-with-webhook-secret
HEXA_RECOVERY_WEBHOOK_TIMEOUT_MS=8000

# Recovery codes are returned by the protocol only when console delivery is
# enabled outside production or in explicitly controlled QA.
HEXA_RECOVERY_EXPOSE_CODE=false

# Optional stable identifier. Omit it when the platform generates unique IDs.
# HEXA_INSTANCE_ID=hexa-node-01

# Public client endpoint example
HEXA_PUBLIC_WS_URL=wss://game.example.com/ws
